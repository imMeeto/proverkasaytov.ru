# ===== Бренд (публичные, попадают в клиентский бандл) =====
NEXT_PUBLIC_SITE_NAME="Проверка сайтов по законам РФ"
NEXT_PUBLIC_SITE_URL="https://проверкасайтов.рф"

# ===== Инфраструктура =====
DATABASE_URL="postgres://lawcheck:lawcheck@localhost:5432/lawcheck"
REDIS_URL="redis://localhost:6379"

# Внутренний адрес app для воркера (PDF-рендер печатной версии). В проде: http://app:3000
APP_INTERNAL_URL="http://localhost:3000"

# ===== Воркер / скан =====
WORKER_CONCURRENCY=2
SCAN_MAX_PAGES=10
SCAN_TOTAL_TIMEOUT_MS=150000
# Путь к локальным базам GeoLite2 (Фаза 2)
GEOIP_DB_PATH="./data/geoip/GeoLite2-Country.mmdb"
GEOIP_ASN_DB_PATH="./data/geoip/GeoLite2-ASN.mmdb"

# ===== Безопасность =====
# HMAC-секрет для печатной версии отчёта (Фаза 4)
REPORT_PRINT_SECRET="change-me-report-print-secret"
# bcrypt-хеш пароля для /admin (Фаза 5)
ADMIN_PASSWORD_HASH=""
# Соль для хеширования IP в rate-limit (Фаза 2)
IP_HASH_SALT="change-me-ip-salt"

# ===== Yandex SmartCaptcha (Фаза 5) =====
SMARTCAPTCHA_SERVER_KEY=""
NEXT_PUBLIC_SMARTCAPTCHA_CLIENT_KEY=""

# ===== Оплата ЮKassa (Фаза 4) =====
PRICE_FULL_REPORT_KOPECKS=70000
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
WEBHOOK_IP_CHECK=1

# ===== Yandex S3 для PDF (Фаза 4) =====
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ===== SMTP (Фаза 4) =====
SMTP_HOST="localhost"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Проверка сайтов <noreply@localhost>"
